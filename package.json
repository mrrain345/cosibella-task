{
  "name": "cosibella-task",
  "version": "1.0.0",
  "description": "Cosibella recruitment task",
  "main": "src/main.ts",
  "scripts": {
    "start": "npm start --prefix app",
    "dev": "npm run dev --prefix app",
    "docker:start": "docker compose up --build -d",
    "docker:stop": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "docker:logs": "docker compose logs -f",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build --watch",
    "db:generate": "npm run db:generate --prefix app",
    "db:migrate": "npm run db:migrate --prefix app",
    "db:push": "npm run db:push --prefix app",
    "db:setup": "npm run docker:start && npm run db:generate && npm run db:migrate; npm run docker:stop",
    "db:clean": "docker compose -f docker-compose.dev.yml down --volumes; rm -rf ./drizzle",
    "test": "npm run test --prefix app",
    "test:watch": "npm run test:watch --prefix app"
  },
  "author": "Kamil Majewski",
  "license": "MIT",
  "workspaces": [
    "app"
  ]
}
